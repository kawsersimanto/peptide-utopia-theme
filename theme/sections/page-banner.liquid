{{ 'page-banner.css' | asset_url | stylesheet_tag }}

<section
  class="section section--page-width page-banner-section"
  style="
    --padding-top: {{ section.settings.padding_top }}px;
    --padding-bottom: {{ section.settings.padding_bottom }}px;
    --padding-mobile-top: {{ section.settings.padding_mobile_top }}px;
    --padding-mobile-bottom: {{ section.settings.padding_mobile_bottom }}px;
  "
>
  <div class="tw:w-full">
    <div class="tw:bg-[#EDEDED] tw:py-7 tw:px-8 tw:rounded-2xl tw:max-w-275 tw:mx-auto tw:flex tw:flex-col tw:items-center tw:justify-center tw:gap-3">
      <h2 class="tw:text-3xl!">{{ section.settings.heading }}</h2>
      <div
        class="tw:block tw:w-20 tw:h-0.75 tw:mx-auto tw:mt-3 tw:bg-linear-to-r tw:from-[#00CFFF] tw:to-[#8A4DFF] tw:rounded-full"
      ></div>
      <div>{{ section.settings.description }}</div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Page Banner",
  "tag": "section",
  "class": "page-width",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Page Title",
      "default": "Page Title"
    },
    {
      "type": "richtext",
      "id": "description",
      "label": "Page Description",
      "default": "<p>Add a description for this page.</p>"
    },
    {
      "type": "header",
      "content": "Section Padding"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Padding Top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "default": 40
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Padding Bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "default": 40
    },
    {
      "type": "header",
      "content": "Mobile Padding"
    },
    {
      "type": "range",
      "id": "padding_mobile_top",
      "label": "Mobile Padding Top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "default": 40
    },
    {
      "type": "range",
      "id": "padding_mobile_bottom",
      "label": "Mobile Padding Bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "default": 40
    }
  ],
  "presets": [
    {
      "name": "Page Banner"
    }
  ]
}
{% endschema %}
