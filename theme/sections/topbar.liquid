<style>
  .topbar-header {
    --topbar-text-size: {{ section.settings.primary_font_size }}px;
    --topbar-text-weight: {{ section.settings.primary_font_weight }};
    --topbar-desc-size: {{ section.settings.secondary_font_size }}px;
    --topbar-desc-weight: {{ section.settings.secondary_font_weight }};

    background: linear-gradient(
      {{ section.settings.gradient_angle }}deg,
      {{ section.settings.gradient_start }},
      {{ section.settings.gradient_end }}
    );
    padding: {{ section.settings.padding_vertical }}px {{ section.settings.padding_horizontal }}px;
    text-align: center;
  }

  .topbar-header-text {
    margin: 0;
    color: {{ section.settings.text_color }};
    font-size: var(--topbar-text-size);
    font-weight: var(--topbar-text-weight);
    line-height: 1.2em;
  }

  .topbar-header-description {
    margin: 0;
    color: {{ section.settings.text_color }};
    font-size: var(--topbar-desc-size);
    font-weight: var(--topbar-desc-weight);
    line-height: 1.2em;
  }
</style>

{% if section.settings.show_topbar %}
  <div class="tw:flex tw:flex-col tw:gap-1.5 topbar-header">
    {% if section.settings.primary_message != blank %}
      <p class="topbar-header-text">{{ section.settings.primary_message }}</p>
    {% endif %}
    {% if section.settings.secondary_message != blank %}
      <p class="topbar-header-description">{{ section.settings.secondary_message }}</p>
    {% endif %}
  </div>
{% endif %}

{% schema %}
{
  "name": "Topbar",
  "enabled_on": {
    "groups": ["header"]
  },
  "tag": "section",
  "class": "topbar-section",
  "limit": 1,
  "settings": [
    {
      "type": "header",
      "content": "Visibility"
    },
    {
      "type": "checkbox",
      "id": "show_topbar",
      "label": "Show topbar",
      "default": true
    },
    {
      "type": "header",
      "content": "Messages"
    },
    {
      "type": "text",
      "id": "primary_message",
      "label": "Primary message",
      "default": "Card Payments Now Available 💳"
    },
    {
      "type": "text",
      "id": "secondary_message",
      "label": "Secondary message",
      "default": "Orders placed before 12 PM AEST dispatch the same day."
    },
    {
      "type": "header",
      "content": "Colors"
    },
    {
      "type": "color",
      "id": "gradient_start",
      "label": "Gradient start color",
      "default": "#78f7f1"
    },
    {
      "type": "color",
      "id": "gradient_end",
      "label": "Gradient end color",
      "default": "#c490f8"
    },
    {
      "type": "range",
      "id": "gradient_angle",
      "label": "Gradient angle",
      "min": 0,
      "max": 360,
      "step": 5,
      "unit": "deg",
      "default": 90
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text color",
      "default": "#000000"
    },
    {
      "type": "header",
      "content": "Typography - Primary"
    },
    {
      "type": "range",
      "id": "primary_font_size",
      "label": "Primary font size",
      "min": 10,
      "max": 32,
      "step": 1,
      "unit": "px",
      "default": 16
    },
    {
      "type": "select",
      "id": "primary_font_weight",
      "label": "Primary font weight",
      "options": [
        { "value": "400", "label": "Regular" },
        { "value": "500", "label": "Medium" },
        { "value": "600", "label": "Semi Bold" },
        { "value": "700", "label": "Bold" }
      ],
      "default": "600"
    },
    {
      "type": "header",
      "content": "Typography - Secondary"
    },
    {
      "type": "range",
      "id": "secondary_font_size",
      "label": "Secondary font size",
      "min": 10,
      "max": 24,
      "step": 1,
      "unit": "px",
      "default": 14
    },
    {
      "type": "select",
      "id": "secondary_font_weight",
      "label": "Secondary font weight",
      "options": [
        { "value": "400", "label": "Regular" },
        { "value": "500", "label": "Medium" },
        { "value": "600", "label": "Semi Bold" }
      ],
      "default": "400"
    },
    {
      "type": "header",
      "content": "Spacing"
    },
    {
      "type": "range",
      "id": "padding_vertical",
      "label": "Vertical padding",
      "min": 4,
      "max": 32,
      "step": 2,
      "unit": "px",
      "default": 8
    },
    {
      "type": "range",
      "id": "padding_horizontal",
      "label": "Horizontal padding",
      "min": 8,
      "max": 64,
      "step": 4,
      "unit": "px",
      "default": 16
    }
  ],
  "presets": [
    {
      "name": "Topbar"
    }
  ]
}
{% endschema %}
